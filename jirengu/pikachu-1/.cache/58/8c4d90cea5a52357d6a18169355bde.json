n.mouth,\n.mouth_main {\n  position: absolute;\n  left: 50%;\n  right: 50%;\n}\n.mouth_main {\n  top: 15px;\n  width: 130px;\n  height: 140px;\n  background: #cc4143;\n  border: 3px solid #000;\n  border-bottom-left-radius: 280px 590px;\n  border-bottom-right-radius: 280px 590px;\n  overflow: hidden;\n  margin-left: -65px;\n}\n.tongue {\n  width: 140px;\n  height: 140px;\n  background: #dd666a;\n  margin-top: 20px;\n  margin-left: -10px;\n  margin-right: -10px;\n  border-top-left-radius: 380px;\n  border-top-right-radius: 380px;\n}\n\n.face {\n  position: absolute;\n  width: 64px;\n  height: 64px;\n  border-radius: 50%;\n  background: #ff5140;\n  border: 2px solid #000;\n  top: 85px;\n  left: 50%;\n  margin-left: -32px;\n}\n.face.left {\n  transform: translateX(-130px);\n}\n.face.right {\n  transform: translateX(130px);\n}\n"},"lineCount":197}},"error":null,"hash":"3da6e27ad55361d1f9e3150a8b58c359","cacheData":{"env":{}}}