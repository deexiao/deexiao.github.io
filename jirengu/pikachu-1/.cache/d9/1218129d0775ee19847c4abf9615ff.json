ayer.ui.demo.innerText = string.substr(0, player.n);\n    player.ui.demo2.innerHTML = string.substr(0, player.n);\n    player.ui.demo.scrollTop = player.ui.demo.scrollHeight;\n  },\n\n  // 播放\n  play: () => {\n    window.clearInterval(player.id);\n    player.id = setInterval(player.run, player.time);\n  },\n\n  // 暂停\n  pause: () => {\n    window.clearInterval(player.id);\n  },\n\n  // 慢速\n  slow: () => {\n    player.pause();\n    player.time = 300;\n    player.play();\n  },\n\n  // 正常速度\n  normal: () => {\n    player.pause();\n    player.time = 100;\n    player.play();\n  },\n\n  // 快速\n  fast: () => {\n    player.pause();\n    player.time = 0;\n    player.play();\n  },\n};\n\nplayer.init();\n"},"lineCount":null}},"error":null,"hash":"8acc64d383286e408602b9ab134e4ff2","cacheData":{"env":{}}}